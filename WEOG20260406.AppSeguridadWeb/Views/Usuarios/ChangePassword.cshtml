@model WEOG20260406.AppSeguridadWeb.Models.Usuario

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark text-center">
                    <h4 class="mb-0"><i class="bi bi-key-fill"></i> @ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Login" />

                        <div class="alert alert-info py-2">
                            <small>Usuario: <strong>@Model.Login</strong></small>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="PasswordHash" class="form-label">Nueva Contraseña</label>
                            <input asp-for="PasswordHash" type="password" class="form-control" />
                            <span asp-validation-for="PasswordHash" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ConfirmarPassword" class="form-label">Confirmar Nueva Contraseña</label>
                            <input asp-for="ConfirmarPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmarPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning fw-bold">
                                Actualizar Contraseña
                            </button>
                            <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


